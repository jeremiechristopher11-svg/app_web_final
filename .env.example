# ==========================================
# CONFIGURATION SUPABASE - EDH PLATEFORME
# ==========================================
# Copiez ce fichier vers .env.local et remplissez vos valeurs Supabase

# URL de votre projet Supabase
# Exemple: https://abcdefghijklmno.supabase.co
VITE_SUPABASE_URL=your_supabase_project_url

# Clé publique anon de votre projet Supabase
# Cette clé est sûre à exposer côté client
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ==========================================
# COMMENT OBTENIR CES VALEURS:
# ==========================================
# 1. Allez sur https://supabase.com
# 2. Créez un nouveau projet (ou utilisez un existant)
# 3. Allez dans Settings > API
# 4. Copiez "Project URL" dans VITE_SUPABASE_URL
# 5. Copiez "anon public" key dans VITE_SUPABASE_ANON_KEY
# ==========================================
